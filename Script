import csv
from datetime import datetime
import re
from urllib.parse import urljoin
import requests
from bs4 import BeautifulSoup


def parse_date_string(date_str):
    """Helper to convert string dates to datetime objects for sorting."""
    # Strip any trailing commas or extra whitespace
    cleaned_str = date_str.replace(",", "").strip()

    # Try common CivicEngage date formats
    for fmt in ("%B %d %Y", "%b %d %Y", "%m/%d/%Y", "%Y-%m-%d"):
        try:
            return datetime.strptime(cleaned_str, fmt)
        except ValueError:
            continue

    # Return min date as fallback for items without a valid date
    return datetime.min


def fetch_and_filter_press_releases():
    base_url = "https://www.burkenc.org"
    news_url = "https://www.burkenc.org/m/newsflash?cat=17&searchTerms=&sortBy=0"

    headers = {
        "User-Agent": (
            "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
            "AppleWebKit/537.36 (KHTML, like Gecko) "
            "Chrome/120.0.0.0 Safari/537.36"
        )
    }

    response = requests.get(news_url, headers=headers)
    if response.status_code != 200:
        print(f"Failed to retrieve data. Status code: {response.status_code}")
        return

    soup = BeautifulSoup(response.text, "html.parser")

    # Target keywords to filter
    keywords = ["zoning", "permit", "permits", "rezoning", "special use"]

    records = []

    # Find list items or container blocks
    items = soup.find_all(["li", "div"], class_=re.compile(r"item|news", re.I))

    if not items:
        items = soup.find_all(["p", "div", "li"])

    for item in items:
        text_content = item.get_text(separator=" ", strip=True)

        # Match target keywords
        if any(kw.lower() in text_content.lower() for kw in keywords):
            # Extract Link & Title
            link_tag = item.find("a", href=True)
            if not link_tag and item.name == "a":
                link_tag = item

            title = link_tag.get_text(strip=True) if link_tag else "N/A"
            link = urljoin(base_url, link_tag["href"]) if link_tag else ""

            # Extract Posted Date
            date_match = re.search(
                r"Posted\s+(?:on[:\s]*)?([A-Za-z]+\s+\d{1,2},?\s+\d{4})",
                text_content,
                re.IGNORECASE,
            )

            if date_match:
                date_posted_str = date_match.group(1).strip()
                dt_object = parse_date_string(date_posted_str)
            else:
                date_posted_str = "Unknown / Not Listed"
                dt_object = datetime.min

            # Avoid adding duplicates
            if title != "N/A" and not any(r["Title"] == title for r in records):
                records.append(
                    {
                        "Date Posted": date_posted_str,
                        "Title": title,
                        "Summary / Content": text_content,
                        "URL": link,
                        "_parsed_date": dt_object,  # Used solely for sorting
                    }
                )

    # -------------------------------------------------------------
    # Sort Records by Date (Newest First)
    # Change reverse=False if you want oldest first
    # -------------------------------------------------------------
    records.sort(key=lambda x: x["_parsed_date"], reverse=True)

    # Clean up temporary sort key before saving to CSV
    for record in records:
        del record["_parsed_date"]

    # Save to CSV
    csv_filename = "burke_county_zoning_permits.csv"
    fieldnames = ["Date Posted", "Title", "Summary / Content", "URL"]

    with open(csv_filename, mode="w", newline="", encoding="utf-8") as file:
        writer = csv.DictWriter(file, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(records)

    print(
        f"Successfully extracted and sorted {len(records)} press releases into '{csv_filename}'."
    )


if __name__ == "__main__":
    fetch_and_filter_press_releases()
